#!/bin/bash

tmp_dir="/tmp/cliphist_icons"
mkdir -p "$tmp_dir"

# Hier definieren wir dein Cozy-Theme
THEME="$HOME/.config/rofi/config.rasi"

cliphist list | while read -r line; do
    # Wir brauchen die ID für cliphist decode
    id=$(echo "$line" | cut -f1)
    content=$(echo "$line" | cut -f2-)
    
    if [[ "$content" == *"[[ binary data"* ]]; then
        icon_path="$tmp_dir/${id}.png"
        # Bild nur generieren, wenn es noch nicht im Temp-Ordner liegt
        if [ ! -f "$icon_path" ]; then
            cliphist decode "$id" > "$icon_path" 2>/dev/null
        fi
        # Wir übergeben die komplette "$line" inkl. ID an Rofi, hängen aber das Icon dran
        echo -en "$line\0icon\x1f$icon_path\n"
    else
        echo -en "$line\n"
    fi
# Rofi wird mit deinem Theme, aktivierten Icons und einer fixen Icon-Größe gestartet
done | rofi -dmenu -i -p "Clipboard" -show-icons -theme "$THEME" -theme-str 'element-icon { size: 40px; }' | cliphist decode | wl-copy
